# Database
DATABASE_URL=postgresql://lock:lock@localhost:5432/lock

# OpenAI (embeddings)
OPENAI_API_KEY=sk-...

# Anthropic (conflict classification)
ANTHROPIC_API_KEY=sk-ant-...

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...

# App
API_PORT=3000
SLACK_PORT=3001
NODE_ENV=development

# Internal secret for service-to-service auth
INTERNAL_SECRET=change-me-to-a-random-string

# Telemetry (opt-in) — sends anonymous daily heartbeat with aggregate stats
# No decision content, user names, or API keys are ever sent.
# See packages/core/src/services/telemetry-service.ts for details.
LOCK_TELEMETRY=false
