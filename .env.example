# Database
DATABASE_URL=postgresql://lock:lock@localhost:5432/lock

# OpenAI (embeddings)
OPENAI_API_KEY=sk-...

# Anthropic (conflict classification)
ANTHROPIC_API_KEY=sk-ant-...

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...

# App
API_PORT=3000
SLACK_PORT=3001
NODE_ENV=development

# Internal secret for service-to-service auth
INTERNAL_SECRET=change-me-to-a-random-string

# ── Hosted SaaS (optional — not needed for self-hosted) ──

# Auth
AUTH_SECRET=change-me-to-a-random-64-char-string
APP_URL=http://localhost:3001
API_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3001

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (optional — emails are logged to console without this)
RESEND_API_KEY=re_...
EMAIL_FROM=Lock <noreply@uselock.ai>

# Stripe billing (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_TEAM=price_...
STRIPE_PRICE_ID_BUSINESS=price_...

# Slack OAuth (SaaS multi-tenant — not needed for self-hosted)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Note: SLACK_SIGNING_SECRET above is also used for SaaS webhook verification

# Telemetry (opt-in) — sends anonymous daily heartbeat with aggregate stats
# No decision content, user names, or API keys are ever sent.
# See packages/core/src/services/telemetry-service.ts for details.
LOCK_TELEMETRY=false

# PostHog analytics (optional — events are skipped if not set)
POSTHOG_KEY=
POSTHOG_HOST=
